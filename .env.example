DISCORD_TOKEN=your_bot_token_here
GUILD_ID=123456789012345678

# Telegram → Discord (войны)
TELEGRAM_ENABLED=true
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+79991234567
# TELEGRAM_CODE=12345          # только на один деплой (Railway), потом удалить
# TELEGRAM_PASSWORD=...         # если 2FA
# TELEGRAM_DUMP_SESSION=true    # после логина — скопировать сессию из Deploy Logs
# TELEGRAM_SESSION_B64=...      # сессия для Railway (python tg_export_session.py)
# TELEGRAM_META_B64=...         # meta для Railway
# ЛС: 123456789  или канал: -1001234567890  или @username
# TELEGRAM_CHATS=1857832136
# TELEGRAM_DEBUG=true   # сырой текст из TG
# BOT_VERBOSE=true      # подробный лог в терминал

# Embed статистики — /война-канал
WAR_CHANNEL_ID=1234567890123456789
# Запрос скрина и фото — /война-канал-скрины
WAR_REPORT_CHANNEL_ID=1234567890123456789
# Тег при запросе скрина (или /война-роль)
WAR_PING_ROLE_IDS=1234567890123456789
# Секунд ждать скрин (1800 = 30 мин)
WAR_SCREENSHOT_TIMEOUT_SEC=1800
# Панель кулдаунов — /война-канал-кд
# WAR_CD_CHANNEL_ID=1234567890123456789
# WAR_ATTACK_CD_MINUTES=240
# WAR_DEFENSE_CD_MINUTES=180
